{
  "name": "mini-orchestrator",
  "version": "1.22.5",
  "description": "Mini orchestrator on top of Claude Code — keeps the project state and sends Claude only the essentials.",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "llm",
    "cli",
    "orchestrator",
    "workflow",
    "agent",
    "project-management",
    "phases",
    "typescript"
  ],
  "license": "MIT",
  "author": "Stanislav Kremeň",
  "homepage": "https://miniorchestrator.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/czsoftcode/mini-orchestrator.git"
  },
  "bugs": {
    "url": "https://github.com/czsoftcode/mini-orchestrator/issues"
  },
  "type": "module",
  "bin": {
    "mini": "dist/cli.js"
  },
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.mjs",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "measure-tokens": "tsx scripts/measure-prompt-tokens.ts",
    "install-local": "bash scripts/install-local.sh",
    "uninstall-local": "rm -f ~/.local/bin/mini && rm -rf ~/.local/share/mini"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "typescript": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  }
}
